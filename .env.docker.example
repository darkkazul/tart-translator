PORT=8787
TART_API_HOST=0.0.0.0
TART_STATIC_DIR=dist/client

# If Ollama runs in another container on the same Docker network, change
# "host.docker.internal" to that service name.
OLLAMA_TAGS_URL=http://host.docker.internal:11434/api/tags
OLLAMA_GENERATE_URL=http://host.docker.internal:11434/api/generate
OLLAMA_MODEL=llama3.2:3b

# Optional only if whisper.cpp is installed inside the container or mounted in.
# For macOS, run Whisper beside the app instead of inside Docker.
# WHISPER_CPP_BIN=/usr/local/bin/whisper-cli
# WHISPER_MODEL_PATH=/models/ggml-small.en.bin
# WHISPER_LANGUAGE=en
