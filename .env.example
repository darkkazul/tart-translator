PORT=8787
TART_API_HOST=127.0.0.1
TART_API_ORIGIN=http://127.0.0.1:8787
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=5173

# Optional local LLM integration.
OLLAMA_TAGS_URL=http://127.0.0.1:11434/api/tags
OLLAMA_GENERATE_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3.2:3b

# Optional local whisper.cpp integration for uploaded audio.
WHISPER_CPP_BIN=/path/to/whisper.cpp/build/bin/whisper-cli
WHISPER_MODEL_PATH=/path/to/whisper.cpp/models/ggml-small.en.bin
WHISPER_LANGUAGE=en
WHISPER_NO_GPU=true
